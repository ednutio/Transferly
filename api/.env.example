# Required for local setup
REDIS_URL=redis://localhost:6379
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-paypal-sandbox-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Common app settings
NODE_ENV=development
PORT=3000
SQLITE_DATABASE_PATH=./data/transferly.sqlite
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token

# PayPal
PAYPAL_ENVIRONMENT=sandbox

# Telegram Mini App
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MINI_APP_URL=http://localhost:5173/miniapp

# Optional auth
USER_API_TOKENS=

# Optional queue/development controls
INLINE_QUEUE_MODE=false
JOB_WAIT_MS=30000

# Optional risk/rate-limit controls
MAX_SINGLE_PAYOUT=1000
DAILY_PAYOUT_LIMIT=5000
MAX_PAYOUTS_PER_HOUR=5
HIGH_RISK_COUNTRIES=RU,IR,KP,SY
HIGH_RISK_CURRENCIES=RUB,IRR,KPW,SYP
SUSPICIOUS_INVOICE_KEYWORDS=crypto,investment,loan,casino,gift card
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_MS=60000

# Optional provider integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECTED_ACCOUNT_ID=
STRIPE_PAYOUTS_ENABLED=false
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_WEBHOOK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
CRYPTO_COMMERCE_API_KEY=
CRYPTO_COMMERCE_WEBHOOK_SECRET=
# EMAIL_DELIVERY_WEBHOOK_URL=https://example.com/email-webhook

# Optional PayPal sandbox smoke test
PAYPAL_SANDBOX_INVOICE_RECIPIENT_EMAIL=
PAYPAL_SANDBOX_PAYOUT_RECEIVER=
PAYPAL_SANDBOX_INVOICE_AMOUNT=12.50
PAYPAL_SANDBOX_PAYOUT_AMOUNT=5.00
PAYPAL_SANDBOX_CURRENCY=USD

# Optional demo seed overrides
SEED_USER_ID=demo-user
SEED_USER_EMAIL=demo@transferly.local
SEED_USER_NAME=Demo User
